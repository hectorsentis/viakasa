# App
NEXT_PUBLIC_SITE_URL=https://www.viakasa.es
PAYLOAD_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgres://user:password@host:5432/viakasa

# Initial owner used by `npm run seed`
INITIAL_ADMIN_EMAIL=admin@viakasa.es
INITIAL_ADMIN_PASSWORD=change-this-password
INITIAL_ADMIN_NAME=Equipo Viakasa

# Cloudinary media
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=viakasa

# Email provider: smtp, resend, or empty while configuring
EMAIL_PROVIDER=
EMAIL_FROM_NAME=Viakasa
EMAIL_FROM_ADDRESS=info@viakasa.es
CONTACT_TO_EMAIL=info@viakasa.es

# SMTP: IONOS, Gmail, or any SMTP-compatible provider
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Resend
RESEND_API_KEY=
