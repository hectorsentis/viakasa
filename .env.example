# App
NEXT_PUBLIC_SITE_URL=https://www.viakasa.es
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Supabase/Postgres
# Payload uses DATABASE_URL first, then POSTGRES_URL_NON_POOLING, POSTGRES_URL, POSTGRES_PRISMA_URL.
DATABASE_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
POSTGRES_HOST=
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSL_REJECT_UNAUTHORIZED=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Initial owner used by `npm run seed`
INITIAL_ADMIN_EMAIL=admin@viakasa.es
INITIAL_ADMIN_PASSWORD=change-this-password
INITIAL_ADMIN_NAME=Equipo Viakasa

# Vercel Blob media
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=
BLOB_WEBHOOK_PUBLIC_KEY=

# Email provider: smtp, resend, or empty while configuring
EMAIL_PROVIDER=
EMAIL_FROM_NAME=Viakasa
EMAIL_FROM_ADDRESS=info@viakasa.es
CONTACT_TO_EMAIL=info@viakasa.es

# SMTP: IONOS, Gmail, or any SMTP-compatible provider
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Resend
RESEND_API_KEY=
